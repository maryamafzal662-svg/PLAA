<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect all traffic to the dist directory if not already there
  RewriteCond %{REQUEST_URI} !^/dist/
  RewriteRule ^(.*)$ dist/$1 [L]

  # If a file/directory doesn't exist inside dist, route to index.html (SPA routing)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^dist/(.*)$ dist/index.html [L]
</IfModule>
